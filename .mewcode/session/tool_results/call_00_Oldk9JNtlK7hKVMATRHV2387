+                                + "  list — 列出所有存档会话\n"
+                                + "  info — 显示当前会话信息";
+                    };
+                });
+
+        // ── /memory (LOCAL) ──────────────────────────────────────────
+        register(new Command("memory", "管理自动记忆 (list / clear)",
+                        new String[]{}, "/memory [list|clear]",
+                        CommandType.LOCAL, "list|clear", false),
+                ctx -> {
