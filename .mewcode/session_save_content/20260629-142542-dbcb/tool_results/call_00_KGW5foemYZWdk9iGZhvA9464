   323	    private ToolResult executeBackground(SubAgentSpec subAgentSpec, String description,
   324	                                          String prompt, String modelOverride,
   325	                                          String name, String isolation) {
   326	        // Worktree isolation via AgentWorktree API
   327	        AgentWorktree.Result worktreeResult = null;
   328	        if ("worktree".equals(isolation) && worktreeManager != null) {
   329	            String slug = generateWorktreeSlug();
   330	            try {
   331	                worktreeResult = AgentWorktree.create(slug, worktreeManager.getProjectRoot(),
   332	                        worktreeManager.getSymlinkDirs());
   333	            } catch (Exception e) {
   334	                return new ToolResult(false,
   335	                        "Error creating agent worktree: " + e.getMessage(), "WORKTREE_FAILED");
   336	            }
   337	        }
   338	
   339	        String effectivePrompt = prompt;
   340	        if (worktreeResult != null) {
   341	            String notice = AgentWorktree.buildNotice(System.getProperty("user.dir"),
   342	                    worktreeResult.worktreePath());
   343	            effectivePrompt = notice + "\n\n" + effectivePrompt;
   344	        }
   345	
   346	        ConversationManager subConversationManager = new ConversationManager();
   347	
   348	        if (subAgentSpec.systemPromptOverride() != null && !subAgentSpec.systemPromptOverride().isEmpty()) {
   349	            subConversationManager.getMessagesMutable().add(
   350	                    new com.mewcode.conversation.Message("user",
   351	                            "<system-reminder>\n" + subAgentSpec.systemPromptOverride() + "\n</system-reminder>"));
   352	        }
   353	
   354	        subConversationManager.addUserMessage(effectivePrompt);
   355	
   356	        // Build tool filter — async definition-based
   357	        boolean isFork = "_fork".equals(subAgentSpec.name());
   358	        Predicate<String> toolFilter = ToolFilter.buildFilter(subAgentSpec, true, isFork);
   359	
   360	        String workDir = worktreeResult != null ? worktreeResult.worktreePath() : workingDirectory;
   361	        AgentLoop subAgent = createSubAgent(subConversationManager, subAgentSpec, toolFilter, modelOverride, name, workDir);
   362	
   363	        return launchBackgroundTask(subAgent, subAgentSpec, description, name, worktreeResult);
   364	    }
