   809	    /**
   810	     * Force a Layer 2 compaction and reset the circuit breaker.
   811	     * Called by error recovery and /compact command.
   812	     */
   813	    public String forceCompact() {
   814	        List<Map<String, Object>> toolSchemas = buildToolSchemas();
   815	        String result = ContextCompactor.forceCompact(
   816	                conversation, provider, contextWindow, recoveryState, toolSchemas);
   817	        compactTracking.reset();
   818	        return result;
   819	    }
