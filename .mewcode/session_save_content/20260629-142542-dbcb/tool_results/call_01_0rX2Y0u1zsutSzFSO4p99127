   188	    public void respondToPermission(String choice) {
   189	        String upper = choice != null ? choice.trim().toUpperCase() : "";
   190	        switch (upper) {
   191	            case "Y" -> permissionResponseQueue.offer(PermissionResponse.ALLOW);
